<div class="news">
  {% capture news_content %}{% include news_content.md %}{% endcapture %}
  {% if include.limit %}
    <style>.news-limited h3 { display: none; }</style>
    <div class="news-limited">
      {{ news_content | markdownify }}
    </div>
    <script>
      var limit = {{ page.announcements.limit | default: 3 }};
      Array.from(document.querySelectorAll('.news-limited li')).forEach(function(li, i) {
        if (i >= limit) li.style.display = 'none';
      });
    </script>
  {% else %}
    {{ news_content | markdownify }}
  {% endif %}
</div>
